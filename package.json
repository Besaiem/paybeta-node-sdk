{
  "name": "@paybeta/node",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the Paybeta payments API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "release": "release-it",
    "release:dry": "release-it --dry-run"
  },
  "keywords": ["paybeta", "payments", "escrow", "sdk", "nigeria", "ngn"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^8.0.0",
    "@types/node": "^20.0.0",
    "release-it": "^17.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0"
  }
}
